// =================================================================
// === MAIN JS - BẢN VÁ LỖI TOÀN DIỆN CHO TRAINHAAI.XYZ ===
// =================================================================

// --- 1. TIỆN ÍCH DÙNG CHUNG ---
window.toggleDescription = function(btn) {
    const descriptionContainer = document.getElementById('noidung-target');
    if (!descriptionContainer) return;
    descriptionContainer.classList.toggle('expanded');
    btn.textContent = descriptionContainer.classList.contains('expanded') ? 'Thu gọn' : 'Đọc thêm';
};

function getTimeAgo(dateString) {
    const date = new Date(dateString);
    if (isNaN(date.getTime())) return "Mới đây";
    const now = new Date();
    const diffDays = Math.round((new Date(now.getFullYear(), now.getMonth(), now.getDate()) - new Date(date.getFullYear(), date.getMonth(), date.getDate())) / 86400000);
    const diffSecs = Math.floor((now - date) / 1000);
    if (diffDays < 7) {
        if (diffSecs < 60) return "vừa xong";
        if (diffSecs < 3600) return Math.floor(diffSecs / 60) + " phút trước";
        if (diffSecs < 86400) return Math.floor(diffSecs / 3600) + " giờ trước";
        return diffDays + " ngày trước";
    }
    return date.getDate().toString().padStart(2, '0') + '/' + (date.getMonth() + 1).toString().padStart(2, '0') + '/' + date.getFullYear();
}

// --- 2. LOGIC MỤC LỤC (CREATE TOC) ---
async function createChapterLinksForNovelLabel(novelLabel) {
    const labelValue = novelLabel.getAttribute('label');
    if (novelLabel.dataset.loaded === 'true') return;
    novelLabel.dataset.loaded = 'true';

    const nameNovelDiv = document.createElement('div');
    nameNovelDiv.className = 'name-novel';
    nameNovelDiv.textContent = labelValue;
    const optionNovel = novelLabel.querySelector('.img-novel');
    if (!optionNovel) return;
    novelLabel.insertBefore(nameNovelDiv, optionNovel);

    const chapterNovel = document.createElement('div');
    chapterNovel.className = 'chapter-novel';
    optionNovel.appendChild(chapterNovel);

    let startIndex = 1;
    let hasMore = true;
    while (hasMore) {
        try {
            const response = await fetch(`/feeds/posts/default/-/${encodeURIComponent(labelValue)}?alt=json&max-results=150&start-index=${startIndex}`);
            const data = await response.json();
            const entries = data.feed.entry || [];
            entries.filter(e => !e.category.some(c => c.term === 'Series')).forEach(post => {
                const link = post.link.find(l => l.rel === 'alternate').href;
                const a = document.createElement('a');
                a.href = link;
                a.innerHTML = `<span>${post.title.$t}</span><span>${getTimeAgo(post.published.$t)}</span>`;
                chapterNovel.appendChild(a);
            });
            hasMore = entries.length === 150;
            startIndex += 150;
        } catch (e) { hasMore = false; }
    }
}

// --- 3. KHỞI CHẠY CÁC TÍNH NĂNG UI ---
function initAllFeatures() {
    // Fix mô tả thu gọn
    const des = document.getElementById('noidung-target');
    if (des && document.body.classList.contains('pv')) {
        const btn = des.nextElementSibling;
        if (btn && btn.classList.contains('read-more-btn')) {
            setTimeout(() => { if (des.scrollHeight > 100) { des.classList.add('is-needing-expansion'); btn.style.display = 'block'; } }, 500);
        }
    }
    // Chạy Mục lục Novel
    document.querySelectorAll('.novel-label').forEach(label => createChapterLinksForNovelLabel(label));
    // Dọn rác tiêu đề
    const title = document.querySelector('body.pv h3.post-title.entry-title');
    if (title) title.querySelectorAll('*').forEach(c => c.innerHTML = c.innerHTML.trim());
    // Timeago
    document.querySelectorAll('time.timeago').forEach(el => {
        const iso = el.getAttribute('datetime');
        if (iso) el.textContent = getTimeAgo(iso);
    });
}

// --- 4. HỆ THỐNG FIREBASE (VIEW/COMMENT/AUTH) ---
function runFirebaseSystem() {
    const configEl = document.querySelector('.firebase-config-json');
    if (!configEl || typeof firebase === 'undefined') return;
    
    if (!firebase.apps.length) firebase.initializeApp(JSON.parse(configEl.textContent));
    const auth = firebase.auth();
    const db = firebase.firestore();
    const rtdb = firebase.database();

    // Logic View Count
    const viewEl = document.querySelector(".viewpost");
    if (viewEl) {
        const postId = viewEl.getAttribute("data-id");
        const viewed = JSON.parse(sessionStorage.getItem('v_p') || '[]');
        const postRef = rtdb.ref('views/' + postId);
        if (!viewed.includes(postId)) {
            postRef.transaction(curr => (curr || 0) + 1);
            viewed.push(postId);
            sessionStorage.setItem('v_p', JSON.stringify(viewed));
        }
        postRef.on('value', snap => {
            const count = viewEl.querySelector(".view-count");
            if (count) count.textContent = (snap.val() || 0).toLocaleString('vi-VN');
        });
    }

    // Auth & Comment Logic (Gói gọn)
    auth.onAuthStateChanged(user => {
        const loginBtn = document.getElementById('login-button');
        const profileBtn = document.getElementById('user-profile-button');
        if (user) {
            if(loginBtn) loginBtn.style.display = 'none';
            if(profileBtn) {
                profileBtn.style.display = 'flex';
                document.getElementById('header-user-avatar').src = user.photoURL;
                document.getElementById('header-user-display-name').textContent = user.displayName;
            }
        }
    });

    // Sự kiện nút Login
    const btnL = document.getElementById('login-button');
    if(btnL) btnL.onclick = () => auth.signInWithRedirect(new firebase.auth.GoogleAuthProvider());
}

// Kích hoạt khi trang sẵn sàng
document.addEventListener('DOMContentLoaded', () => {
    initAllFeatures();
    const checkFB = setInterval(() => {
        if (typeof firebase !== 'undefined' && typeof firebase.database === 'function') {
            clearInterval(checkFB);
            runFirebaseSystem();
        }
    }, 200);
});
